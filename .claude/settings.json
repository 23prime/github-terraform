{
  "permissions": {
    "allow": [
      "Bash(gh repo list:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh api users/*:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(mise run:*)"
    ],
    "ask": [
      "Bash(mise run tf-apply:*)",
      "Bash(mise tf-apply:*)",
      "Read(*.tfvars)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "mise run fix 2>&1 || true",
            "statusMessage": "Running fix..."
          }
        ]
      }
    ]
  }
}
